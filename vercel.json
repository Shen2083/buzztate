{
  "buildCommand": "npx tsx script/generate-blog-data.ts && npx vite build && npx tsx script/prerender.ts",
  "outputDirectory": "dist/public",
  "framework": null,
  "redirects": [
    { "source": "/translate/:lang", "destination": "/", "statusCode": 301 }
  ],
  "functions": {
    "api/localize.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
